  "keyFeatures": [
    "Invoice creation, sending, and PDF export",
    "Quote/proposal management with online client acceptance",
    "Client (CRM) management with dossiers and tasks",
    "SEPA direct debit collection via Mollie mandates",
    "Recurring subscription invoices",
    "Automated payment reminders",
    "Bank transaction import and matching (MT940 / Ponto)",
    "Exact Online accounting sync",
    "Multi-administration support",
    "Customizable email templates (NL/EN/DE/FR/ES)",
    "Mileage (ritten) registration and export",
    "Product & inventory management",
    "Credit-based pricing with monthly cap"
  ],
  "publicApiSurface": [
    "POST /webhooks/mollie — Mollie payment webhook",
    "POST /webhooks/ponto — Ponto bank webhook",
    "POST /webhooks/lettermint-inbound — Inbound email webhook",
    "GET /factuur/{token} — Public invoice view",
    "GET /offerte/{token} — Public quote acceptance page",
    "GET /betaal/{token} — Public payment page",
    "GET /machtiging/{token} — Public SEPA mandate page",
    "GET /bank-connections/callback — Ponto OAuth callback",
    "GET /exact-online/callback — Exact Online OAuth callback",
    "GET /minox/callback — Minox OAuth callback"
  ]
